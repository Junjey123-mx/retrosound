NODE_ENV=production

# ── Base de datos (credenciales obligatorias Proyecto 2 Web) ──
POSTGRES_USER=proy2
POSTGRES_PASSWORD=secret
POSTGRES_DB=retrosound

DB_HOST=localhost
DB_USER=proy2
DB_PASSWORD=secret
DB_NAME=retrosound
DB_PORT=5433

# URL de conexión directa para desarrollo local (fuera de Docker)
# Dentro de Docker el backend usa: postgresql://proy2:secret@postgres:5432/retrosound?schema=public
DATABASE_URL=postgresql://proy2:secret@localhost:5433/retrosound?schema=public

# ── Autenticación ──
JWT_SECRET=change-me-in-production

# ── CORS ──
# En Docker el backend recibe FRONTEND_URL construido desde FRONTEND_PORT (ver docker-compose.yml).
# Para desarrollo local fuera de Docker, configura FRONTEND_URL en apps/backend/.env.
FRONTEND_URL=http://localhost:3002

# ── Puertos de la aplicación ──
BACKEND_PORT=3003
FRONTEND_PORT=3002

# ── URL pública del backend (usada por el frontend) ──
VITE_API_URL=http://localhost:3003

# ── pgAdmin ──
PGADMIN_EMAIL=admin@retrosound.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5051
