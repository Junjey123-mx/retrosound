NODE_ENV=production

# ── Base de datos (credenciales obligatorias para calificación) ──
POSTGRES_USER=proy2
POSTGRES_PASSWORD=secret
POSTGRES_DB=retrosound

DB_HOST=localhost
DB_USER=proy2
DB_PASSWORD=secret
DB_NAME=retrosound
DB_PORT=5433

# URL usada por Prisma en desarrollo local (fuera de Docker)
DATABASE_URL=postgresql://proy2:secret@localhost:5433/retrosound?schema=public

# ── Autenticación ──
JWT_SECRET=change-me-in-production

# ── Puertos de la aplicación ──
BACKEND_PORT=3003
FRONTEND_PORT=3002

# ── URL pública del backend (usada por el frontend) ──
NEXT_PUBLIC_API_URL=http://localhost:3003

# ── pgAdmin ──
PGADMIN_EMAIL=admin@retrosound.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5051
