
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum EstadoGeneral {
  activo
  inactivo
}

enum EstadoProducto {
  activo
  inactivo
  agotado
  descontinuado
}

enum EstadoUsuario {
  activo
  bloqueado
  inactivo
}

enum RolUsuario {
  admin
  empleado
  cliente
  proveedor
}

enum EstadoVenta {
  pendiente
  completada
  cancelada
}

enum EstadoCompra {
  pendiente
  recibida
  cancelada
}

// ─── Catálogos ────────────────────────────────────────────────────────────────

model Categoria {
  id          Int           @id @default(autoincrement()) @map("id_categoria")
  nombre      String        @map("nombre_categoria")
  descripcion String?       @map("descripcion_categoria")
  estado      EstadoGeneral @default(activo) @map("estado_categoria")
  productos   Producto[]

  @@map("categoria")
}

model Formato {
  id          Int           @id @default(autoincrement()) @map("id_formato")
  nombre      String        @map("nombre_formato")
  descripcion String?       @map("descripcion_formato")
  estado      EstadoGeneral @default(activo) @map("estado_formato")
  productos   Producto[]

  @@map("formato")
}

model GeneroMusical {
  id          Int              @id @default(autoincrement()) @map("id_genero_musical")
  nombre      String           @map("nombre_genero_musical")
  descripcion String?          @map("descripcion_genero_musical")
  estado      EstadoGeneral    @default(activo) @map("estado_genero_musical")
  productos   ProductoGenero[]

  @@map("genero_musical")
}

model Artista {
  id          Int               @id @default(autoincrement()) @map("id_artista")
  nombre      String            @map("nombre_artista")
  paisOrigen  String?           @map("pais_origen_artista")
  anioInicio  Int?              @map("anio_inicio_artista")
  estado      EstadoGeneral     @default(activo) @map("estado_artista")
  productos   ProductoArtista[]

  @@map("artista")
}

// ─── Producto + tablas asociativas ────────────────────────────────────────────

model Producto {
  id                Int              @id @default(autoincrement()) @map("id_producto")
  titulo            String           @map("titulo_producto")
  descripcion       String?          @map("descripcion_producto")
  anioLanzamiento   Int?             @map("anio_lanzamiento")
  precioVenta       Decimal          @db.Decimal(10, 2) @map("precio_venta")
  stockActual       Int              @default(0) @map("stock_actual")
  stockMinimo       Int              @default(0) @map("stock_minimo")
  codigoSku         String           @unique @map("codigo_sku")
  estado            EstadoProducto   @default(activo) @map("estado_producto")
  fechaInactivacion DateTime?        @db.Date @map("fecha_inactivacion")
  idCategoria       Int              @map("id_categoria")
  idFormato         Int              @map("id_formato")

  categoria      Categoria              @relation(fields: [idCategoria], references: [id])
  formato        Formato                @relation(fields: [idFormato], references: [id])
  artistas       ProductoArtista[]
  generos        ProductoGenero[]
  detallesVenta  DetalleVenta[]
  detallesCompra DetalleCompraProveedor[]

  @@index([titulo], name: "idx_producto_titulo")
  @@map("producto")
}

model ProductoArtista {
  idProducto Int @map("id_producto")
  idArtista  Int @map("id_artista")

  producto Producto @relation(fields: [idProducto], references: [id])
  artista  Artista  @relation(fields: [idArtista], references: [id])

  @@id([idProducto, idArtista])
  @@map("producto_artista")
}

model ProductoGenero {
  idProducto      Int @map("id_producto")
  idGeneroMusical Int @map("id_genero_musical")

  producto      Producto      @relation(fields: [idProducto], references: [id])
  generoMusical GeneroMusical @relation(fields: [idGeneroMusical], references: [id])

  @@id([idProducto, idGeneroMusical])
  @@map("producto_genero")
}

// ─── Personas ─────────────────────────────────────────────────────────────────

model Cliente {
  id                Int           @id @default(autoincrement()) @map("id_cliente")
  nombre            String        @map("nombre_cliente")
  apellido          String        @map("apellido_cliente")
  telefono          String?       @map("telefono_cliente")
  correo            String?       @map("correo_cliente")
  direccion         String?       @map("direccion_cliente")
  fechaRegistro     DateTime      @db.Date @map("fecha_registro_cliente")
  estado            EstadoGeneral @default(activo) @map("estado_cliente")
  fechaInactivacion DateTime?     @db.Date @map("fecha_inactivacion")

  usuario Usuario?
  ventas  Venta[]

  @@index([correo], name: "idx_cliente_correo")
  @@map("cliente")
}

model Empleado {
  id                Int           @id @default(autoincrement()) @map("id_empleado")
  nombre            String        @map("nombre_empleado")
  apellido          String        @map("apellido_empleado")
  telefono          String?       @map("telefono_empleado")
  correo            String?       @map("correo_empleado")
  fechaContratacion DateTime      @db.Date @map("fecha_contratacion")
  estado            EstadoGeneral @default(activo) @map("estado_empleado")
  fechaInactivacion DateTime?     @db.Date @map("fecha_inactivacion")

  usuario Usuario?
  ventas  Venta[]
  compras CompraProveedor[]

  @@map("empleado")
}

model Proveedor {
  id                Int           @id @default(autoincrement()) @map("id_proveedor")
  nombre            String        @map("nombre_proveedor")
  telefono          String?       @map("telefono_proveedor")
  correo            String?       @map("correo_proveedor")
  direccion         String?       @map("direccion_proveedor")
  nombreContacto    String?       @map("nombre_contacto_proveedor")
  estado            EstadoGeneral @default(activo) @map("estado_proveedor")
  fechaInactivacion DateTime?     @db.Date @map("fecha_inactivacion")

  usuario Usuario?
  compras CompraProveedor[]

  @@map("proveedor")
}

// ─── Usuario ──────────────────────────────────────────────────────────────────

model Usuario {
  id                Int           @id @default(autoincrement()) @map("id_usuario")
  correo            String        @unique @map("correo_usuario")
  contrasenaHash    String        @map("contrasena_hash")
  rol               RolUsuario    @map("rol_usuario")
  estado            EstadoUsuario @default(activo) @map("estado_usuario")
  fechaInactivacion DateTime?     @db.Date @map("fecha_inactivacion")
  idCliente         Int?          @unique @map("id_cliente")
  idEmpleado        Int?          @unique @map("id_empleado")
  idProveedor       Int?          @unique @map("id_proveedor")

  cliente   Cliente?   @relation(fields: [idCliente], references: [id])
  empleado  Empleado?  @relation(fields: [idEmpleado], references: [id])
  proveedor Proveedor? @relation(fields: [idProveedor], references: [id])

  @@map("usuario")
}

// ─── Ventas ───────────────────────────────────────────────────────────────────

model Venta {
  id          Int         @id @default(autoincrement()) @map("id_venta")
  fechaVenta  DateTime    @db.Date @map("fecha_venta")
  descuento   Decimal     @default(0.00) @db.Decimal(10, 2) @map("descuento_venta")
  metodoPago  String      @map("metodo_pago")
  estado      EstadoVenta @default(pendiente) @map("estado_venta")
  idCliente   Int         @map("id_cliente")
  idEmpleado  Int         @map("id_empleado")

  cliente  Cliente        @relation(fields: [idCliente], references: [id])
  empleado Empleado       @relation(fields: [idEmpleado], references: [id])
  detalles DetalleVenta[]

  @@index([fechaVenta], name: "idx_venta_fecha")
  @@map("venta")
}

model DetalleVenta {
  id               Int     @id @default(autoincrement()) @map("id_detalle_venta")
  idVenta          Int     @map("id_venta")
  idProducto       Int     @map("id_producto")
  cantidadVendida  Int     @map("cantidad_vendida")
  precioUnitario   Decimal @db.Decimal(10, 2) @map("precio_unitario_venta")
  descuentoDetalle Decimal @default(0.00) @db.Decimal(10, 2) @map("descuento_detalle")

  venta    Venta    @relation(fields: [idVenta], references: [id])
  producto Producto @relation(fields: [idProducto], references: [id])

  @@unique([idVenta, idProducto])
  @@map("detalle_venta")
}

// ─── Compras a proveedor ──────────────────────────────────────────────────────

model CompraProveedor {
  id          Int          @id @default(autoincrement()) @map("id_compra_proveedor")
  fechaCompra DateTime     @db.Date @map("fecha_compra_proveedor")
  estado      EstadoCompra @default(pendiente) @map("estado_compra")
  idProveedor Int          @map("id_proveedor")
  idEmpleado  Int          @map("id_empleado")

  proveedor Proveedor                @relation(fields: [idProveedor], references: [id])
  empleado  Empleado                 @relation(fields: [idEmpleado], references: [id])
  detalles  DetalleCompraProveedor[]

  @@map("compra_proveedor")
}

model DetalleCompraProveedor {
  id                  Int     @id @default(autoincrement()) @map("id_detalle_compra_proveedor")
  idCompraProveedor   Int     @map("id_compra_proveedor")
  idProducto          Int     @map("id_producto")
  cantidadComprada    Int     @map("cantidad_comprada")
  costoUnitarioCompra Decimal @db.Decimal(10, 2) @map("costo_unitario_compra")

  compraProveedor CompraProveedor @relation(fields: [idCompraProveedor], references: [id])
  producto        Producto        @relation(fields: [idProducto], references: [id])

  @@unique([idCompraProveedor, idProducto])
  @@map("detalle_compra_proveedor")
}
