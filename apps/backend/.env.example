# ── Base de datos ──────────────────────────────────────────────
# Dentro de Docker (backend → postgres service):
DATABASE_URL=postgresql://proy2:secret@postgres:5432/retrosound?schema=public

# Desarrollo local (backend fuera de Docker, Postgres en :5433):
# DATABASE_URL=postgresql://proy2:secret@localhost:5433/retrosound?schema=public

# ── Autenticación ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── CORS ───────────────────────────────────────────────────────
# Origen permitido por el guard CORS del backend (main.ts lee FRONTEND_URL)
# En Docker Compose este valor lo inyecta docker-compose.yml via FRONTEND_PORT.
FRONTEND_URL=http://localhost:3002

# ── Puerto del backend ─────────────────────────────────────────
PORT=3001
NODE_ENV=development
